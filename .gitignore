# Environment
.env

# Storage (runtime files, keep directory structure)
storage/cache/*
storage/logs/*
storage/sessions/*
!storage/cache/.gitkeep
!storage/logs/.gitkeep
!storage/sessions/.gitkeep

# User uploads (keep directory structure)
public/uploads/blog/*
public/uploads/logos/*
public/uploads/signatures/*
!public/uploads/blog/.gitkeep
!public/uploads/logos/.gitkeep
!public/uploads/signatures/.gitkeep

# Dompdf runtime font metric cache (regenerated on first use)
vendor/dompdf/dompdf/lib/fonts/*.afm.json

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log
