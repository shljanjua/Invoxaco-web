# =========================================================
# Invoxaco - Environment Configuration
# Copy this file to .env and fill in real values before deploy.
# Never commit the real .env file.
# =========================================================

APP_NAME="Invoxaco"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://invoxaco.com
APP_KEY=
APP_TIMEZONE=UTC

# Database (Hostinger MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=invoxaco
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Mail / SMTP (overridable per-install from Admin > SMTP Settings, these are fallback/bootstrap values)
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=support@invoxaco.com
MAIL_FROM_NAME="Invoxaco"

# Session / Security
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_DECAY_MINUTES=15

# Payments (modular - leave blank until a gateway is enabled in Admin)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PADDLE_VENDOR_ID=
PADDLE_API_KEY=
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=

# Analytics
GA4_MEASUREMENT_ID=
GSC_VERIFICATION=
CLARITY_PROJECT_ID=
META_PIXEL_ID=

# Single Admin Bootstrap (used only by setup/install.php to seed the one admin account)
ADMIN_NAME="Site Admin"
ADMIN_EMAIL=admin@invoxaco.com
ADMIN_PASSWORD=
